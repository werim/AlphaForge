# AlphaForge environment template
# Copy this file to .env and fill in real values locally.
# Never commit your real .env file.

# --- Runtime environment ---
# Application mode: dev, test, or prod.
ALPHAFORGE_ENVIRONMENT=dev

# --- Exchange credentials (placeholders only) ---
# Binance API key used for authenticated account and order endpoints.
BINANCE_API_KEY=your_binance_api_key_here
# Binance API secret paired with BINANCE_API_KEY.
BINANCE_API_SECRET=your_binance_api_secret_here
# Optional: use Binance testnet in non-production workflows.
BINANCE_TESTNET=true

# --- Database configuration ---
# Primary database URL override.
# Examples:
#   sqlite:///./alphaforge.db
#   postgresql+psycopg://user:pass@localhost:5432/alphaforge
ALPHAFORGE_DATABASE_URL=sqlite:///./alphaforge.db

# Optional explicit database targets for environment-specific tooling.
ALPHAFORGE_SQLITE_PATH=sqlite:///./alphaforge.db
ALPHAFORGE_POSTGRES_URL=postgresql+psycopg://postgres:postgres@localhost:5432/alphaforge

# --- Logging ---
# Logging level: DEBUG, INFO, WARNING, ERROR, CRITICAL.
ALPHAFORGE_LOG_LEVEL=INFO

# --- Trading mode switches ---
# Exactly one mode should be enabled in normal operation.
ALPHAFORGE_ENABLE_PAPER_TRADING=true
ALPHAFORGE_ENABLE_LIVE_TRADING=false
# Safety gate: live orders should require explicit confirmation flag.
ALPHAFORGE_ALLOW_LIVE_ORDERS=false

# --- Risk controls ---
# Max account risk per trade, in percent.
ALPHAFORGE_RISK_PCT_PER_TRADE=1.0
# Daily max loss limit, in percent of account equity.
ALPHAFORGE_MAX_DAILY_LOSS_PCT=3.0
# Max concurrent open positions.
ALPHAFORGE_MAX_OPEN_POSITIONS=3
# Minimum setup score required before taking a trade.
ALPHAFORGE_MIN_TRADE_SCORE=0.50

# --- Execution cost assumptions ---
# Assumed fees and slippage for simulation and planning.
ALPHAFORGE_TAKER_FEE_PCT=0.040
ALPHAFORGE_MAKER_FEE_PCT=0.020
ALPHAFORGE_EXPECTED_SLIPPAGE_PCT=0.050

# --- Backtest defaults ---
ALPHAFORGE_BACKTEST_ENABLED=true
# Initial account balance for backtests.
ALPHAFORGE_BACKTEST_INITIAL_BALANCE=1000
# Candle interval used when not explicitly provided.
ALPHAFORGE_BACKTEST_TIMEFRAME=1m
# Number of candles loaded per symbol in backtest runs.
ALPHAFORGE_BACKTEST_CANDLE_LIMIT=1500

# --- Symbol selection defaults ---
# Comma-separated symbol universe and defaults.
ALPHAFORGE_DEFAULT_SYMBOLS=BTCUSDT,ETHUSDT
ALPHAFORGE_DEFAULT_QUOTE_ASSET=USDT
ALPHAFORGE_MAX_SYMBOLS=20
