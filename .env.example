# AlphaForge environment template (production-grade defaults with LIVE disabled)
# Copy to .env and set real secrets locally: cp .env.example .env
# Never commit .env.

# Environment
ALPHAFORGE_ENVIRONMENT=dev # Runtime environment label: dev/test/prod
ALPHAFORGE_TIMEZONE=UTC # Operational timezone for logs/scheduling

# Runtime Mode
ALPHAFORGE_MODE=PAPER # BACKTEST | PAPER | LIVE (default PAPER for safety)
EXECUTION_MODE=PAPER # Backward-compatible alias used by runtime entrypoints
ALPHAFORGE_ENABLE_BACKTEST=true # Enable backtest workflows/tools
ALPHAFORGE_ENABLE_PAPER_TRADING=true # Enable paper execution path
ALPHAFORGE_ENABLE_LIVE_TRADING=false # Keep LIVE disabled by default
ALPHAFORGE_ALLOW_LIVE_ORDERS=false # Hard safety gate for real order placement
ALPHAFORGE_REQUIRE_LIVE_QUALIFICATION=true # Enforce readiness gate before LIVE startup
ALPHAFORGE_ENABLE_SHADOW_MODE=true # Required for controlled LIVE qualification rollout
ALPHAFORGE_ENABLE_CANARY_MODE=true # Required for controlled LIVE qualification rollout
ALPHAFORGE_OPERATOR_LIVE_ACKNOWLEDGED=false # Manual operator ack required before LIVE
ALPHAFORGE_GLOBAL_KILL_SWITCH=false # Emergency stop for runtime order flow
ALPHAFORGE_DRY_RUN=true # Safety default for scripts/adapters that support dry-run behavior

# Exchange / Binance
BINANCE_BASE_URL=https://fapi.binance.com # Binance Futures REST base URL
BINANCE_WS_URL=wss://fstream.binance.com/ws # Binance Futures websocket base URL
BINANCE_TESTNET=true # Use testnet endpoints where supported
BINANCE_DEFAULT_QUOTE_ASSET=USDT # Default quote asset for universe selection
BINANCE_DEFAULT_MARKET_TYPE=USDT_M # Preferred market type: USDT_M | COIN_M
BINANCE_RECV_WINDOW_MS=5000 # Signed request receive window
BINANCE_REQUEST_TIMEOUT_SEC=10 # HTTP timeout for venue calls

# Hyperliquid
HYPERLIQUID_ENABLED=false # Enable Hyperliquid adapter integration when implemented
HYPERLIQUID_API_URL=https://api.hyperliquid.xyz # Hyperliquid HTTP API base URL
HYPERLIQUID_WS_URL=wss://api.hyperliquid.xyz/ws # Hyperliquid websocket endpoint
HYPERLIQUID_TESTNET=true # Prefer testnet/sandbox where supported

# API Keys
BINANCE_API_KEY=your_binance_api_key_here # Binance API key
BINANCE_API_SECRET=your_binance_api_secret_here # Binance API secret
HYPERLIQUID_API_KEY=your_hyperliquid_api_key_here # Hyperliquid API key
HYPERLIQUID_API_SECRET=your_hyperliquid_api_secret_here # Hyperliquid API secret

# Risk Engine
ALPHAFORGE_RISK_PCT_PER_TRADE=0.5 # Conservative risk per trade (% equity)
ALPHAFORGE_MAX_DAILY_LOSS_PCT=2.0 # Daily max drawdown guard (% equity)
ALPHAFORGE_MAX_OPEN_POSITIONS=3 # Concurrent position cap
ALPHAFORGE_MAX_NOTIONAL_EXPOSURE=100000 # Portfolio notional cap
ALPHAFORGE_MAX_SYMBOL_NOTIONAL=50000 # Per-symbol notional cap
ALPHAFORGE_SYMBOL_COOLDOWN_SEC=120 # Cooldown per symbol between entries
ALPHAFORGE_STALE_MARKET_DATA_SEC=15 # Reject if market data older than this
MAX_CORRELATED_POSITIONS=2 # Correlation exposure cap across similar symbols
REJECT_UNKNOWN_EXPECTANCY=true # Reject trades when expectancy context is unknown

# Execution
ALPHAFORGE_MIN_TRADE_SCORE=0.50 # Minimum decision score threshold
ALPHAFORGE_MIN_RR=1.20 # Minimum raw RR before execution penalties
MIN_EFFECTIVE_RR=1.10 # Minimum execution-adjusted RR
ALPHAFORGE_MAX_CONCURRENT_POSITIONS=3 # Runtime concurrent position cap
ALPHAFORGE_SCAN_INTERVAL_SEC=1.0 # Runtime market scan cadence
ALPHAFORGE_HEARTBEAT_INTERVAL_SEC=30.0 # Runtime heartbeat cadence
ALPHAFORGE_RECONCILIATION_INTERVAL_SEC=5.0 # Reconciliation loop interval
ALPHAFORGE_RECONCILIATION_TIMEOUT_SEC=2.0 # Reconciliation timeout bound

# Slippage / Spread
MAX_SPREAD_BPS=25 # Max spread threshold in basis points
MAX_SLIPPAGE_BPS=20 # Max expected slippage threshold in basis points
ALPHAFORGE_MAX_SPREAD_PCT=0.0025 # Runtime spread limit as percent
ALPHAFORGE_MAX_EXPECTED_SLIPPAGE_PCT=0.0020 # Runtime slippage limit as percent
ALPHAFORGE_MAX_ABS_FUNDING_RATE_PCT=0.0010 # Funding-risk guard as absolute percent
ALPHAFORGE_TAKER_FEE_PCT=0.040 # Assumed taker fee percent for planning
ALPHAFORGE_MAKER_FEE_PCT=0.020 # Assumed maker fee percent for planning
MIN_LIQUIDITY_USD=5000000 # Minimum 24h quote liquidity for tradability
ENABLE_ORDERBOOK_FILTER=true # Use orderbook quality gating
ENABLE_SPOOF_DETECTION=false # Enable spoof-risk detection (off until validated)
ENABLE_ABSORPTION_FILTER=false # Enable absorption/flow filter (off until validated)
ENABLE_REGIME_FILTER=true # Enforce regime-aware filter gating

# Backtest
ALPHAFORGE_BACKTEST_INITIAL_BALANCE=1000 # Default backtest starting balance
ALPHAFORGE_BACKTEST_RISK_PCT=1.0 # Backtest risk per trade
ALPHAFORGE_BACKTEST_TIMEFRAME=1m # Candle timeframe
ALPHAFORGE_BACKTEST_TOP_N=100 # Universe size cap
ALPHAFORGE_BACKTEST_LAST_N_DAYS=7 # Default backtest horizon (days)
ALPHAFORGE_BACKTEST_OUTPUT_DIR=data/backtest # Backtest export directory
ALPHAFORGE_BACKTEST_OFFLINE=false # Use deterministic fixtures instead of network
ALPHAFORGE_BACKTEST_CI=false # CI-safe offline mode

# Persistence
ALPHAFORGE_DATABASE_URL=sqlite:///./alphaforge.db # Primary DB URL override
ALPHAFORGE_SQLITE_PATH=sqlite:///./alphaforge.db # SQLite DB path fallback
ALPHAFORGE_POSTGRES_URL=postgresql+psycopg://postgres:postgres@localhost:5432/alphaforge # Postgres URL for non-dev env
ALPHAFORGE_DB_ECHO=false # SQLAlchemy echo SQL logs
ALPHAFORGE_EXPORT_VERIFY_INTEGRITY=true # Fail exports on lifecycle/reject mismatch

# Redis / Queue
REDIS_ENABLED=false # Toggle Redis-backed cache/queue integrations
REDIS_URL=redis://localhost:6379/0 # Redis DSN
REDIS_KEY_PREFIX=alphaforge # Key namespace prefix
QUEUE_BACKEND=memory # memory | redis
QUEUE_NAME=alphaforge_runtime # Queue/stream name

# Logging
ALPHAFORGE_LOG_LEVEL=INFO # DEBUG | INFO | WARNING | ERROR
ALPHAFORGE_LOG_FORMAT=json # json | text
ALPHAFORGE_LOG_FILE= # Optional file path; empty = stdout only
ALPHAFORGE_METRICS_HEARTBEAT_ENABLED=true # Emit periodic runtime heartbeat metrics

# Notifications
ALPHAFORGE_ENABLE_NOTIFICATIONS=false # Master notification toggle
ALPHAFORGE_ENABLE_TELEGRAM=false # Telegram notifications toggle
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here # Telegram bot token
TELEGRAM_CHAT_ID=your_telegram_chat_id_here # Telegram target chat
ALPHAFORGE_ENABLE_DISCORD=false # Discord notifications toggle
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/replace_me # Discord webhook URL

# Feature Flags
ALPHAFORGE_ENABLE_LIVE_READINESS=true # Enable live-readiness evaluator subsystem
ALPHAFORGE_ENABLE_RECONCILIATION=true # Enable reconciliation control-plane loop
ALPHAFORGE_ENABLE_REJECT_SHADOW_ANALYTICS=true # Enable rejected-trade shadow evaluation summaries

# Experimental
ALPHAFORGE_EXPERIMENTAL_EXCHANGE_REPAIR=false # Allow automated exchange repair actions
ALPHAFORGE_EXPERIMENTAL_ADAPTIVE_THRESHOLDS=false # Enable adaptive threshold experiments

# Debug
ALPHAFORGE_DEBUG=false # Global debug toggle
ALPHAFORGE_TRACE_LIFECYCLE=false # Verbose lifecycle transition tracing
ALPHAFORGE_DUMP_EXECUTION_CTX=false # Emit execution context payloads for diagnostics
